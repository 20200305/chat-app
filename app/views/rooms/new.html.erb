<div class='chat-room-form'>
  <h1>新規チャットルーム</h1>
  <%=form_with model: @room, local: true do |f|%>
    <div class='chat-room-form__field'>
      <div class='chat-room-form__field--left'>
        <%= f.label :チャットルーム名, class: 'chat-room-form__label'%>
      </div>
      <div class='chat-room-form__field--right'>
        <%= f.text_field :name, class: 'chat__room_name chat-room-form__input', placeholder: 'チャットルーム名を入力してください'%>
      </div>
    </div>
    <div class='chat-room-form__field'>
    </div>
    <div class='chat-room-form__field'>
      <div class='chat-room-form__field--left'>
        <label class='chat-room-form__label' for='chat_room_チャットメンバー'>チャットメンバー</label>
      </div>
      <div class='chat-room-form__field--right'>
      <%# ここだけでは選択したユーザーしか部屋に行かない %>
        <select name = "room[user_ids] []">
          <option>チャットするユーザーを選択してください</option>
          <% User.all.where.not(id: current_user.id).each do |user| %>
          <option value=<%= user.id %>><%= user.name %></option>
          <%end%>
        </select>
                                  <%# hiddenで目に見えないデーターで送る %>
        <input name="room[user_ids][]" type = "hidden" value = <%=current_user%>>
        <%# imput,nameで最初のやつのdi({"room[user_ids][]" => "選択したユーザーのid"})の中に
        カレントユーザーもぶちこむ↓
        {"room[user_ids][]" => "選択したユーザーのid, 現在ログインしているユーザーのid"}の形になる %>
      </div>
    </div>
    <div class='chat-room-form__field'>
      <div class='chat-room-form__field--left'></div>
      <div class='chat-room-form__field--right'>
        <%= f.submit class: 'chat-room-form__action-btn'%>
      </div>
    </div>
  <% end %>
</div>
